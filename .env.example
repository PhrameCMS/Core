# Default container engine. If unset, core auto-selects (prefers configured dependency-injection bridges when available).
# Allowed values: native, dependency-injection, or a custom FQCN
PHRAME_CONTAINER=dependency-injection

# Default transport selection. If unset, core auto-selects (prefers configured bridge implementations when available).
# Allowed values: native, http-foundation, or a custom FQCN
PHRAME_HTTP_TRANSPORT=http-foundation

# Default routing engine. If unset, core auto-selects (prefers configured routing bridges when available).
# Allowed values: native, routing-bridge, symfony-routing, or a custom FQCN
PHRAME_ROUTING_ENGINE=routing-bridge

# Optional dotenv bridge override. If unset, core uses the default dotenv bridge package when available.
# Allowed value: Fully\Qualified\ClassName implementing PhrameCMS\Core\Contracts\DotenvBridgeInterface
# PHRAME_DOTENV_BRIDGE=Vendor\Package\MyDotenvBridge
