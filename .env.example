# Default container engine. If unset, core auto-selects (prefers Symfony DI adapter).
# Allowed values: native, symfony, symfony-di, dependency-injection, or a custom FQCN
PHRAME_CONTAINER=symfony

# Default transport selection. If unset, core auto-selects (prefers Symfony bridge when installed).
# Allowed values: native, symfony, httpfoundation, http-foundation, or a custom FQCN
PHRAME_HTTP_TRANSPORT=symfony
