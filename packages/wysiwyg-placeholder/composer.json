{
  "name": "lumecms/wysiwyg-placeholder",
  "description": "Optional WYSIWYG capability plugin for LumeCMS Core",
  "type": "library",
  "license": "GPL-3.0-only",
  "require": {
    "php": "^8.2",
    "lumecms/core": "*"
  },
  "autoload": {
    "psr-4": {
      "Lume\\Plugin\\WysiwygPlaceholder\\": "src/"
    }
  },
  "extra": {
    "lume": {
      "provider": "Lume\\Plugin\\WysiwygPlaceholder\\WysiwygServiceProvider",
      "capabilities": [
        "editor.wysiwyg"
      ]
    }
  }
}
