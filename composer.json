{
  "name": "phramecms/core",
  "description": "Plugin-first CMS core runtime for PhrameCMS",
  "type": "library",
  "license": "GPL-3.0-only",
  "require": {
    "php": "^8.2",
    "psr/container": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "PhrameCMS\\Core\\": "src/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "packages/wysiwyg",
      "options": {
        "symlink": true
      }
    }
  ],
  "suggest": {
    "phramecms/wysiwyg": "Optional WYSIWYG capability plugin"
  },
  "scripts": {
    "serve": "php -S 127.0.0.1:8080 -t public public/index.php"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}